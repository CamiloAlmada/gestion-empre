rules_version = '2';

// Reglas de Firestore — app quesería (Fase 1).
//
// Postura base: deny por defecto. Toda operación de dominio exige un usuario
// autenticado CON documento en `usuarios/{uid}` y `activo == true`. Sobre esa
// base se autoriza por colección y por rol ('admin' | 'vendedor') según
// docs/02-dominio-quesarte.md ("Colecciones" y "Reglas de seguridad") y la nota
// "Auth y alta de usuarios (v2)" de docs/04-plan-fases.md.
//
// Modelo de roles:
// - admin: puede todo.
// - vendedor: lee catálogo/stock y crea ventas/movimientos; NO edita precios,
//   compras, usuarios ni configuración. Los únicos writes de dominio que puede
//   hacer son los EFECTOS de una venta (bajar stock de productos/piezas), y solo
//   sobre los campos exactos que eso toca.
//
// Nota de costo: los get() al doc `usuarios/{uid}` se referencian siempre por la
// misma ruta, de modo que Firestore reutiliza (cachea) la lectura dentro de una
// misma evaluación de reglas. Mantener esa estructura evita multiplicar lecturas.

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---

    // Hay un usuario autenticado en la request.
    function estaAutenticado() {
      return request.auth != null;
    }

    // El usuario autenticado tiene documento en `usuarios/{uid}` y está activo.
    // Cuesta lecturas (exists + get): usar SOLO en reglas de colecciones que
    // NO sean la propia lectura de `usuarios/{uid}`.
    function usuarioActivo() {
      return estaAutenticado()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo == true;
    }

    // El usuario autenticado y activo tiene rol 'admin'.
    function esAdmin() {
      return usuarioActivo()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // El usuario autenticado y activo tiene rol 'vendedor'.
    function esVendedor() {
      return usuarioActivo()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'vendedor';
    }

    // El write cambia únicamente los campos listados (defensa contra edición de
    // campos no permitidos, ej. precios, en updates de vendedor).
    function soloCambian(campos) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(campos);
    }

    // Piso cero para el stock agregado de productos tras un efecto de venta del
    // vendedor. Con `increment()`, `request.resource.data` ya contiene el valor
    // RESULTANTE del campo (verificado contra el emulador en la suite de reglas),
    // así que un decremento que dejaría el stock negativo se rechaza acá.
    // `get(campo, 0)` tolera que el producto no tenga ese campo (un granel no
    // tiene `stockUnidades` y viceversa): ausente ⇒ 0, que satisface el piso.
    function stockAgregadoNoNegativo() {
      let d = request.resource.data;
      return d.get('stockGranelGramos', 0) >= 0 && d.get('stockUnidades', 0) >= 0;
    }

    // Monotonía del stock agregado para el vendedor: una venta solo puede BAJAR
    // `stockGranelGramos`/`stockUnidades`, nunca subirlos (cierra el hueco de Fase
    // 1: hasta acá solo las piezas tenían monotonía). El valor RESULTANTE del
    // increment no puede superar al actual. Ingresos por compra y la reversa de
    // una anulación (que SÍ suben el stock) son de admin, que usa su propia regla.
    // `get(campo, 0)` en ambos lados neutraliza el campo ausente (0 <= 0).
    function stockAgregadoNoSube() {
      let vieja = resource.data;
      let nueva = request.resource.data;
      return nueva.get('stockGranelGramos', 0) <= vieja.get('stockGranelGramos', 0)
        && nueva.get('stockUnidades', 0) <= vieja.get('stockUnidades', 0);
    }

    // Shape estricto para invitar un usuario (create de admin): exactamente
    // { nombre, email, rol in ['admin','vendedor'], activo: bool }.
    function usuarioInvitacionValida() {
      let d = request.resource.data;
      return d.keys().hasOnly(['nombre', 'email', 'rol', 'activo'])
        && d.keys().hasAll(['nombre', 'email', 'rol', 'activo'])
        && d.nombre is string && d.nombre.size() > 0
        && d.email is string && d.email.size() > 0
        && d.rol in ['admin', 'vendedor']
        && d.activo is bool;
    }

    // Update de usuario (admin): solo activo/rol/nombre; email inmutable
    // (queda fuera de affectedKeys) y sin agregar campos nuevos.
    function usuarioUpdateValido() {
      let d = request.resource.data;
      return d.diff(resource.data).affectedKeys().hasOnly(['activo', 'rol', 'nombre'])
        && d.rol in ['admin', 'vendedor']
        && d.activo is bool
        && d.nombre is string && d.nombre.size() > 0;
    }

    // Shape estricto de una categoría (create/update de admin): exactamente
    // { nombre: string no vacío, orden: int >= 0 }. `orden is int` rechaza floats
    // (2.5) y `>= 0` rechaza negativos.
    function categoriaValida() {
      let d = request.resource.data;
      return d.keys().hasOnly(['nombre', 'orden'])
        && d.keys().hasAll(['nombre', 'orden'])
        && d.nombre is string && d.nombre.size() > 0
        && d.orden is int && d.orden >= 0;
    }

    // Claves permitidas de un cliente (doc 07 + `telefonoE164` de doc 08). Ninguna
    // otra puede aparecer, ni en el alta rápida del vendedor ni en la edición del
    // admin. `telefonoE164` es el número derivado que consume el link `wa.me`.
    function clienteClavesConocidas() {
      return request.resource.data.keys().hasOnly(
        ['nombre', 'alias', 'telefono', 'telefonoE164', 'email', 'direccion', 'notas',
         'fechaAlta', 'activo', 'stats']);
    }

    // `telefonoE164` (doc 08), si está presente, es E.164 sin `+`: solo dígitos,
    // 8-15 (mismo rango plausible que `normalizarTelefono` en `core`). Ausente es
    // válido (no hay teléfono normalizable). No exige coherencia con `telefono`
    // display: eso es responsabilidad del kit (lo deriva), no de las reglas.
    function telefonoE164ValidoSiPresente(d) {
      return !('telefonoE164' in d)
        || (d.telefonoE164 is string && d.telefonoE164.matches('^[0-9]{8,15}$'));
    }

    // Shape estricto para el ALTA de un cliente (create de vendedor o admin): el
    // vendedor hace alta rápida en el POS, así que se valida acá igual que la
    // invitación de usuario. `nombre` obligatorio no vacío, `activo` nace true, y
    // `stats` NACE EN CERO Y SIN FECHAS: `primeraCompra`/`ultimaCompra` las escriben
    // las VENTAS (increments), nunca el alta, así que ni siquiera se admiten como
    // claves acá. Los datos de contacto opcionales, si vienen, deben ser strings
    // (el vendedor los crea desde el mostrador; el "no vacío" es criterio de UI).
    function clienteAltaValida() {
      let d = request.resource.data;
      return clienteClavesConocidas()
        && d.keys().hasAll(['nombre', 'fechaAlta', 'activo', 'stats'])
        && d.nombre is string && d.nombre.size() > 0
        && d.activo == true
        && (!('alias' in d) || d.alias is string)
        && (!('telefono' in d) || d.telefono is string)
        && telefonoE164ValidoSiPresente(d)
        && (!('email' in d) || d.email is string)
        && (!('direccion' in d) || d.direccion is string)
        && (!('notas' in d) || d.notas is string)
        && d.stats.keys().hasOnly(['cantidadVentas', 'totalHistoricoCents'])
        && d.stats.cantidadVentas == 0
        && d.stats.totalHistoricoCents == 0;
    }

    // Update de VENDEDOR sobre un cliente: SOLO el cache `stats`, y solo con los
    // deltas de UNA venta. Con `increment()`, `request.resource.data` trae el valor
    // RESULTANTE, así que se compara contra `resource.data`: `cantidadVentas` sube
    // exactamente 1 y `totalHistoricoCents` sube estrictamente (una venta suma
    // plata) Y sigue siendo entero (`is int` rechaza un increment fraccionario que
    // corrompería los centésimos). El contador ya queda forzado a int por el `+1`.
    // `hasOnly` sobre las 4 claves conocidas impide colar sub-claves basura dentro
    // de `stats`. Esto bloquea +2, decrementos (la reversa de la anulación es de
    // admin) y tocar datos de contacto. Las fechas de `stats` pueden cambiar (cache).
    function clienteStatsDeltaVenta() {
      let vieja = resource.data.stats;
      let nueva = request.resource.data.stats;
      return soloCambian(['stats'])
        && nueva.keys().hasOnly(['cantidadVentas', 'totalHistoricoCents', 'primeraCompra', 'ultimaCompra'])
        && nueva.cantidadVentas == vieja.cantidadVentas + 1
        && nueva.totalHistoricoCents is int
        && nueva.totalHistoricoCents > vieja.totalHistoricoCents;
    }

    // Shape de UNA plantilla de WhatsApp (doc 08): exactamente
    // { id, nombre, texto, contexto in ['venta','cliente','inactivo'] }, strings
    // acotados. Se aplica al primer elemento de la lista (ver `plantillasWhatsAppValidas`).
    function plantillaWhatsAppValida(p) {
      return p is map
        && p.keys().hasOnly(['id', 'nombre', 'texto', 'contexto'])
        && p.keys().hasAll(['id', 'nombre', 'texto', 'contexto'])
        && p.id is string && p.id.size() >= 1 && p.id.size() <= 40
        && p.nombre is string && p.nombre.size() >= 1 && p.nombre.size() <= 60
        && p.texto is string && p.texto.size() >= 1 && p.texto.size() <= 1000
        && p.contexto in ['venta', 'cliente', 'inactivo'];
    }

    // Shape estricto de `configuracion/plantillasWhatsApp` (doc 08): un único doc
    // con la clave `plantillas` (lista de ≤ 20 mapas). LÍMITE PRÁCTICO: el lenguaje
    // de reglas no itera listas de largo arbitrario, así que se valida el TAMAÑO de
    // la lista + su única clave + el shape del PRIMER elemento como representante.
    // La validación exhaustiva por elemento (largos, contexto de cada plantilla, ids
    // únicos) la hace `guardarPlantillasWhatsApp` en el kit, client-side, antes de
    // escribir; estas reglas son el backstop de shape (ver reporte WA-B).
    function plantillasWhatsAppValidas() {
      let d = request.resource.data;
      return d.keys().hasOnly(['plantillas'])
        && d.plantillas is list
        && d.plantillas.size() <= 20
        && (d.plantillas.size() == 0 || plantillaWhatsAppValida(d.plantillas[0]));
    }

    // --- Colecciones ---

    match /usuarios/{uid} {
      // Cada usuario lee su propio doc: la comparación de uid ES la verificación
      // de identidad, por eso NO se exige usuarioActivo() (evita un get() del
      // mismo doc que se está leyendo y permite el guard post-login por `activo`).
      allow read: if estaAutenticado() && request.auth.uid == uid;
      // Admin lee cualquier doc de usuarios (pantalla "Usuarios").
      allow read: if esAdmin();
      // Admin crea la invitación con shape válido; un no-admin no escribe nada.
      allow create: if esAdmin() && usuarioInvitacionValida();
      // Admin actualiza solo activo/rol/nombre (email inmutable).
      allow update: if esAdmin() && usuarioUpdateValido();
      // Nadie borra: los usuarios se desactivan (preservan auditoría).
      allow delete: if false;
    }

    match /categorias/{id} {
      // Vocabulario visible para todo usuario activo (agrupa listas de Stock).
      allow read: if usuarioActivo();
      // Alta y edición (renombrar/reordenar) solo admin, con shape estricto. En
      // update, `soloCambian` limita las claves afectadas a nombre/orden (permite
      // tocar solo una de las dos, p. ej. renombrar sin mover el orden).
      allow create: if esAdmin() && categoriaValida();
      allow update: if esAdmin() && categoriaValida() && soloCambian(['nombre', 'orden']);
      // Regla de dominio: las categorías NO se borran (evita productos huérfanos).
      allow delete: if false;
    }

    match /productos/{id} {
      // Catálogo visible para todo usuario activo.
      allow read: if usuarioActivo();
      // Alta/baja de productos solo admin.
      allow create, delete: if esAdmin();
      // Admin edita cualquier campo del producto.
      allow update: if esAdmin();
      // Vendedor solo ajusta stock agregado como efecto de una venta: nunca lo
      // deja en negativo (piso cero) ni lo SUBE (una venta solo descuenta; los
      // ingresos y la reversa de anulación son de admin).
      allow update: if esVendedor()
        && soloCambian(['stockGranelGramos', 'stockUnidades', 'actualizadoEn'])
        && stockAgregadoNoNegativo()
        && stockAgregadoNoSube();
    }

    match /piezas/{id} {
      // Stock por pieza visible para todo usuario activo.
      allow read: if usuarioActivo();
      // Crear/borrar piezas (ingreso de stock, merma total) solo admin.
      allow create, delete: if esAdmin();
      // Admin edita cualquier campo de la pieza.
      allow update: if esAdmin();
      // Vendedor solo descuenta peso / marca estado por venta; nunca AUMENTA
      // el peso restante (una venta solo puede reducirlo) ni lo deja en negativo
      // (piso cero sobre el valor resultante del increment).
      allow update: if esVendedor()
        && soloCambian(['pesoRestanteGramos', 'estado'])
        && request.resource.data.pesoRestanteGramos <= resource.data.pesoRestanteGramos
        && request.resource.data.pesoRestanteGramos >= 0;
    }

    match /ventas/{id} {
      // Historial visible para todo usuario activo.
      allow read: if usuarioActivo();
      // Cualquier usuario activo (vendedor o admin) registra su propia venta
      // completada con total e items presentes. `clienteId`/`clienteNombre` son
      // opcionales (doc 07): si NO vienen, la venta anónima pasa igual que antes;
      // si vienen, deben ser strings (shape del denormalizado).
      allow create: if usuarioActivo()
        && request.resource.data.usuarioId == request.auth.uid
        && request.resource.data.estado == 'completada'
        && request.resource.data.totalCents is int
        && request.resource.data.items is list
        && (!('clienteId' in request.resource.data) || request.resource.data.clienteId is string)
        && (!('clienteNombre' in request.resource.data) || request.resource.data.clienteNombre is string);
      // Única mutación permitida: anulación por admin (completada -> anulada),
      // sin tocar ningún otro campo (la reversa de stock va por movimientos).
      allow update: if esAdmin()
        && resource.data.estado == 'completada'
        && request.resource.data.estado == 'anulada'
        && soloCambian(['estado']);
      // Las ventas no se borran (auditoría).
      allow delete: if false;
    }

    match /clientes/{id} {
      // Cualquier usuario activo lee clientes (el vendedor los busca en el POS).
      allow read: if usuarioActivo();
      // Alta (rápida o completa): vendedor o admin, con shape estricto y stats en
      // cero (el vendedor da de alta clientes desde el mostrador, doc 07).
      allow create: if usuarioActivo() && clienteAltaValida();
      // Admin edita datos de contacto/activo y revierte el cache de stats al anular
      // (decrementos): puede cambiar cualquier campo conocido, sin introducir
      // claves nuevas (preserva el shape) y con `telefonoE164` bien formado si está
      // presente (doc 08). Un update que SOLO cambia `telefonoE164` (o lo borra) cae
      // acá igual: `clienteClavesConocidas` no exige que cambie tal o cual campo.
      allow update: if esAdmin()
        && clienteClavesConocidas()
        && telefonoE164ValidoSiPresente(request.resource.data);
      // Vendedor solo suma al cache `stats` el efecto de UNA venta (nunca resta ni
      // toca datos de contacto).
      allow update: if esVendedor()
        && clienteClavesConocidas()
        && clienteStatsDeltaVenta();
      // No se borran: se desactivan (activo:false), preservando historial y stats.
      allow delete: if false;
    }

    match /proveedores/{id} {
      // Solo admin: el vendedor no ve datos bancarios ni costos de proveedor
      // (criterio de aceptación del doc 07, verificado por reglas — no solo UI).
      allow read: if esAdmin();
      allow create, update: if esAdmin();
      // No se borran: se desactivan (activo:false).
      allow delete: if false;
    }

    match /movimientos/{id} {
      // Auditoría de stock visible para todo usuario activo.
      allow read: if usuarioActivo();
      // Cualquier usuario activo crea movimientos a su nombre.
      allow create: if usuarioActivo()
        && request.resource.data.usuarioId == request.auth.uid;
      // Inmutables: nunca se actualizan ni se borran.
      allow update, delete: if false;
    }

    match /compras/{id} {
      // Compras (Fase 2, doc 03): solo admin (el vendedor no ve costos de compra).
      allow read: if esAdmin();
      // Una compra NACE como borrador: la confirmación es una TRANSICIÓN de estado,
      // nunca un create directo a 'confirmada' (así no se saltea el flujo de draft).
      allow create: if esAdmin() && request.resource.data.estado == 'borrador';
      // Editable/confirmable SOLO desde borrador: `resource.data.estado ==
      // 'borrador'` garantiza que una compra 'confirmada' sea INMUTABLE (doc 03,
      // "correcciones = ajustes"). La transición válida deja el estado en 'borrador'
      // (sigue editando) o 'confirmada' (efectos ya aplicados en el batch).
      allow update: if esAdmin()
        && resource.data.estado == 'borrador'
        && request.resource.data.estado in ['borrador', 'confirmada'];
      // Se borran solo borradores; una confirmada JAMÁS (auditoría + efectos ya aplicados).
      allow delete: if esAdmin() && resource.data.estado == 'borrador';
    }

    match /configuracion/{id} {
      // Configuración legible por usuario activo; solo admin la modifica.
      allow read: if usuarioActivo();
      // `plantillasWhatsApp` (doc 08): admin, con shape estricto (lista de plantillas).
      allow write: if esAdmin() && id == 'plantillasWhatsApp' && plantillasWhatsAppValidas();
      // `general` y cualquier otro doc de configuración: admin, SIN shape estricto.
      // NOTA WA-B: la instrucción de bloquear `general` a solo
      // {codigoPaisDefault, nombreNegocio} quedó PENDIENTE de decisión del tech lead.
      // Contradice la config viva de Fase 2 que este doc ya guarda
      // (umbralPiezaAgotadaGramos, metodoProrrateo — leída por CompraPantalla y
      // cubierta por un test existente): endurecerla a esas 2 claves borraría esa
      // config (regresión de Fase 2). Se mantiene el comportamiento previo
      // (admin-write) hasta ratificar el shape (superset o doc aparte). Ver reporte.
      allow write: if esAdmin() && id != 'plantillasWhatsApp';
    }

    // Catch-all: deniega explícitamente cualquier otra ruta (refuerza el deny
    // por defecto; no anula los allow específicos de arriba, que se OR-ean).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
